{
  "repositories": [
    "../../lookout-api",
    "../../lookout-control",
    "../../lookout-workers",
    "../../lookout-orchestrator"
  ],
  "severityThreshold": "low",
  "minConfidence": 0.6,
  "excludePatterns": [
    "**/node_modules/**",
    "**/.git/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/*.d.ts",
    "**/*.log",
    "**/test/**",
    "**/tests/**",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.js",
    "**/*.spec.ts",
    "**/*.spec.js",
    "**/scripts/**",
    "**/migrations/**",
    "**/fixtures/**"
  ],
  "checks": {
    "memoryLeaks": true,
    "connectionLeaks": true,
    "cleanupIssues": true,
    "performance": true
  },
  "reporting": {
    "format": "markdown",
    "includeCodeContext": true,
    "postToApi": false,
    "apiUrl": "http://localhost:3456"
  },
  "rag": {
    "enabled": false,
    "confidenceThreshold": 0.7,
    "similarityThreshold": 0.75,
    "useLearnedPatterns": true
  },
  "llm": {
    "enabled": false,
    "model": "gpt-4",
    "maxTokens": 1000
  }
}
