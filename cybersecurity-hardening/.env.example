# Postgres RAG Configuration
# For local dev with lookout-local docker-compose:
POSTGRES_PASSWORD=agents_rag_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_DB=agents_rag
POSTGRES_USER=agent_user

# For standalone use (without lookout-local):
# POSTGRES_PASSWORD=changeme
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5433
# POSTGRES_DB=agents_rag
# POSTGRES_USER=agent_user

# OpenAI API for embeddings (required for RAG)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Learning Configuration
RAG_ENABLED=true
RAG_CONFIDENCE_THRESHOLD=0.6
RAG_SIMILARITY_THRESHOLD=0.75
