{
  "repositories": [
    "../lookout-api",
    "../lookout-control"
  ],
  "openapiPaths": {
    "../lookout-api": "openapi.yaml",
    "../lookout-control": "openapi.yaml"
  },
  "severityThreshold": "low",
  "excludePatterns": [
    "node_modules/**",
    ".git/**",
    "*.log",
    "test/**",
    "**/*.test.ts"
  ],
  "checks": {
    "schemaValidation": true,
    "security": true,
    "versionCompatibility": true,
    "routeCompleteness": true
  },
  "reporting": {
    "format": "markdown",
    "includeCodeContext": true,
    "postToApi": true,
    "apiUrl": "http://localhost:3456"
  },
  "rag": {
    "enabled": false,
    "confidenceThreshold": 0.7,
    "similarityThreshold": 0.75,
    "useLearnedPatterns": true
  },
  "llm": {
    "enabled": false,
    "model": "gpt-4",
    "maxTokens": 1000
  }
}
